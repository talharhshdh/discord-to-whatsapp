# Discord Bot Token
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord Server ID (Guild ID) to listen to
# Right-click on server icon -> Copy Server ID
DISCORD_SERVER_ID=your_server_id_here

# WhatsApp recipient number (with country code, no + or spaces)
# Example: 1234567890 for US number
WHATSAPP_RECIPIENT=recipient_number_here
